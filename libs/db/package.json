{
  "name": "@misoa/db",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "db:migrate": "cd libs/db && npx drizzle-kit migrate --config=drizzle.config.ts",
    "db:migrate:prod": "cd libs/db && DATABASE_URL=$PROD_DATABASE_URL npx drizzle-kit migrate --config=drizzle.config.ts"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@misoa/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "tags": [
      "scope:db"
    ]
  },
  "dependencies": {
    "tslib": "^2.3.0"
  }
}
