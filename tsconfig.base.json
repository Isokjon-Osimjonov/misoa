{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@misoa/shared-types": ["libs/shared-types/src/index.ts"],
      "@misoa/shared-utils": ["libs/shared-utils/src/index.ts"],
      "@misoa/db": ["libs/db/src/index.ts"],
      "@misoa/ui-config": ["libs/ui-config/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "tmp"]
}
