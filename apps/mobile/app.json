{
  "expo": {
    "main": "expo-router/entry",
    "name": "Mobile",
    "slug": "@misoa/mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "@misoa/mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 400,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ]
    ],
    "owner": "isokjon",
    "extra": {
      "apiUrl": "https://api.misoa.uz/api/v1",
      "router": {},
      "eas": {
        "projectId": "587f17a9-a943-43ed-8d06-2d040b255da9"
      }
    }
  }
}
