{
  "name": "@misoa/api",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/apps/api/dist/package.json",
          "{workspaceRoot}/apps/api/dist/pnpm-lock.yaml"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/apps/api/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "@misoa/api:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@misoa/api:build:development"
          },
          "production": {
            "buildTarget": "@misoa/api:build:production"
          }
        }
      }
    },
    "tags": [
      "scope:api"
    ]
  },
  "dependencies": {
    "@bull-board/api": "^7.1.5",
    "@bull-board/express": "^7.1.5",
    "@grammyjs/ratelimiter": "^1.2.1",
    "@misoa/db": "workspace:*",
    "@misoa/shared-types": "workspace:*",
    "@misoa/shared-utils": "workspace:*",
    "@sentry/node": "^10.56.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/node-cron": "^3.0.11",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.0",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "exceljs": "^4.4.0",
    "expo-server-sdk": "^6.1.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "express-slow-down": "^3.1.0",
    "grammy": "^1.43.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "openai": "^6.41.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "slug": "^11.0.1",
    "socket.io": "^4.8.3",
    "tsx": "^4.22.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "20.19.9",
    "@types/pg": "^8.20.0",
    "@types/pino": "^7.0.5",
    "@types/slug": "^5.0.9",
    "pino-pretty": "^13.1.3"
  }
}
